# .claudeignore
# Tells Claude Code which files and directories to skip when reading the
# codebase for context. Follows .gitignore syntax.
#
# Philosophy: exclude build artifacts, generated output, large binary assets,
# secrets, and third-party vendored code. Never exclude source files that
# Claude needs to understand the project structure and logic.

# ── Dependencies & package manager ────────────────────────────────────────
node_modules/
.bun-cache/
bun.lockb

# ── Build outputs ──────────────────────────────────────────────────────────
.next/
dist/
build/
out/
*.tsbuildinfo

# ── Test coverage & reports ────────────────────────────────────────────────
coverage/
.nyc_output/
lcov.info
test-results/
playwright-report/

# ── Supabase local state ───────────────────────────────────────────────────
# migrations/ and seed.sql ARE readable — critical context.
# config.toml IS readable.
supabase/.branches/
supabase/.temp/
supabase/volumes/
supabase/functions/.deploy/

# ── Environment & secrets ──────────────────────────────────────────────────
# .env.example and .env.local.example ARE readable (no real secrets).
.env
.env.local
.env.*.local
.env.production
.env.staging
apps/api/.env
apps/web/.env.local
*.pem
*.key
*.cert

# ── Editor & OS noise ──────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
*.swo
.idea/
# Allow .vscode/settings.json and launch.json (useful context for Claude)
.vscode/extensions.json

# ── Logs ───────────────────────────────────────────────────────────────────
*.log
logs/
npm-debug.log*

# ── Binary & media assets ──────────────────────────────────────────────────
# Raster images and fonts (not useful code context)
*.woff
*.woff2
*.ttf
*.otf
*.png
*.jpg
*.jpeg
*.gif
*.webp
*.ico
# NOTE: *.svg is intentionally NOT ignored.
# SVG files in components/ui/icons/ are source code — Claude should read them.
# Only ignore generated/public SVGs:
apps/web/public/generated/
public/audio/
apps/web/public/audio/

# ── Auto-generated files Claude should NOT edit ────────────────────────────
# Supabase TypeScript type generation output — read the migrations instead.
supabase/types/
apps/api/src/db/database.types.ts
apps/web/src/lib/supabase/database.types.ts

# ── Large data/fixture files ───────────────────────────────────────────────
# Raw JLPT word list downloads (source CSVs, not code)
scripts/data/raw/
# Premade deck JSON export snapshots (generated by seed scripts, not authored)
supabase/seed-data/exports/
# AI regression golden outputs (large JSON blobs)
apps/api/src/test/ai-regression/golden-outputs/

# ── Misc tooling cache ──────────────────────────────────────────────────────
.turbo/
.cache/
*.cache
.image-cache/

# ── Storybook (if added) ───────────────────────────────────────────────────
storybook-static/

# ─────────────────────────────────────────────────────────────────────────────
# INTENTIONALLY NOT IGNORED — do not add these by mistake:
#
#   apps/api/src/**/*.ts          All backend source
#   apps/web/src/**/*.tsx         All frontend source
#   supabase/migrations/**/*.sql  All schema migrations (Claude must read these)
#   packages/shared-types/src/    Canonical TypeScript domain types
#   **/*.test.ts, **/*.test.tsx   Test files (Claude writes and reads tests)
#   **/*.md                       All documentation
#   *.json, *.toml, *.yml         All config files
#   .env.example, .env.local.example  Variable reference (no secrets)
#   **/*.svg in components/       SVG icon source files
# ─────────────────────────────────────────────────────────────────────────────
